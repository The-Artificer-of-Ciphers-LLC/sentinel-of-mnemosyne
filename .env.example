# ============================================================
# Sentinel of Mnemosyne — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# ------------------------------------------------------------
# AI Provider — LM Studio (default)
# LM Studio runs on the Mac Mini and exposes an OpenAI-compatible API at /v1/.
# host.docker.internal resolves to the Docker host (the Mac Mini) from inside containers.
# Start the server in LM Studio under Local Server before use.
# ------------------------------------------------------------
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# Leave blank for local LM Studio (no auth required by default).
# If you enabled API token auth in LM Studio settings, put it here.
LMSTUDIO_API_KEY=

# The model identifier exactly as shown in LM Studio's model list.
PI_MODEL=llama-3.2-8b-instruct

# ------------------------------------------------------------
# Pi Harness (internal Docker network — do not change unless
# you rename the pi-harness service in pi-harness/compose.yml)
# ------------------------------------------------------------
PI_HARNESS_URL=http://pi-harness:3000

# ------------------------------------------------------------
# Obsidian — Mnemosyne Vault
# Install the "Local REST API" community plugin in Obsidian.
# The plugin shows you the API key in its settings panel.
# Default port is 27124 (HTTPS with self-signed cert).
# If Docker runs on the same Mac as Obsidian, use:
#   http://host.docker.internal:27124
# If Docker runs on a different machine, use the Mac's LAN IP.
# ------------------------------------------------------------
OBSIDIAN_API_URL=http://host.docker.internal:27124
OBSIDIAN_API_KEY=paste-your-obsidian-api-key-here

# ------------------------------------------------------------
# Sentinel Core Security
# A shared secret used to authenticate requests from interface
# containers to the Core. Generate a random string — anything
# works, longer is better. Example:
#   openssl rand -hex 32
# ------------------------------------------------------------
SENTINEL_API_KEY=change-this-to-a-random-string

# ------------------------------------------------------------
# Discord Interface (only needed if using the Discord bot)
# Create a bot at https://discord.com/developers/applications
# ------------------------------------------------------------
DISCORD_BOT_TOKEN=
# Comma-separated list of channel IDs the bot will respond in.
# Leave blank to allow all channels (not recommended).
DISCORD_ALLOWED_CHANNELS=
# Channel ID for running integration tests locally.
# Set to a dedicated test channel in your Discord server.
# Leave blank in production — only needed when running pytest integration tests.
# Find channel ID: right-click channel in Discord (Developer Mode must be on) → Copy Channel ID
DISCORD_TEST_CHANNEL_ID=

# ------------------------------------------------------------
# Alpaca Trading (only needed for the Stock Trader module)
# Create a free account at https://alpaca.markets
# Use PAPER keys until you're ready for real money.
# Paper and live are separate key sets — switching modes
# means swapping these values, nothing else.
# ------------------------------------------------------------
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=
# Set to "paper" or "live". Default is paper.
ALPACA_MODE=paper
# Maximum total portfolio value the trader is allowed to manage.
ALPACA_MAX_PORTFOLIO=500
# Maximum single trade size in dollars.
ALPACA_MAX_TRADE_SIZE=50

# ------------------------------------------------------------
# Logging
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during development, INFO in normal use.
# ------------------------------------------------------------
LOG_LEVEL=INFO
