# Discord bot token — from Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Sentinel Core API key — must match sentinel-core/.env SENTINEL_API_KEY
SENTINEL_API_KEY=your-sentinel-api-key-here

# Sentinel Core URL — internal Docker network hostname
SENTINEL_CORE_URL=http://sentinel-core:8000

# Optional: comma-separated channel IDs the bot will respond in (blank = all channels)
DISCORD_ALLOWED_CHANNELS=
