# Sentinel of Mnemosyne deployment environment
# Copy to .env and edit for the host running Docker.

# AI provider
AI_PROVIDER=lmstudio
AI_FALLBACK_PROVIDER=none
MODEL_NAME=gemma-4-e4b-it-mlx
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Optional Claude fallback
CLAUDE_MODEL=claude-haiku-4-5

# Pathfinder LiteLLM settings
LITELLM_MODEL=openai/gemma-4-e4b-it-mlx
LITELLM_API_BASE=http://host.docker.internal:1234/v1
RULES_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Obsidian Local REST API
OBSIDIAN_API_URL=http://host.docker.internal:27123
OBSIDIAN_BASE_URL=http://host.docker.internal:27123
# Set only if Pathfinder's direct Obsidian REST calls require auth.
OBSIDIAN_API_KEY=
# Host path mounted into the Pathfinder container at /vault for archive and Foundry imports.
OBSIDIAN_VAULT_PATH=/Users/you/Documents/Mnemosyne

# Discord interface
DISCORD_ALLOWED_CHANNELS=
DISCORD_NOTIFY_CHANNEL_ID=
SENTINEL_ADMIN_USER_IDS=
DISCORD_BOT_INTERNAL_URL=http://discord-bot:8001

# Foundry / browser CORS
CORS_ALLOW_ORIGINS=http://localhost:30000
CORS_ALLOW_ORIGIN_REGEX=https://.*\.forge-vtt\.com

# Session notes
SESSION_AUTO_RECAP=false
SESSION_TZ=America/New_York
# SESSION_RECAP_MODEL=

# Foundry narration
# FOUNDRY_NARRATION_MODEL=

# Runtime
LOG_LEVEL=INFO
